# AudioCapBench - Credentials Template
# Copy this file to credentials.env and fill in your API keys:
#   cp credentials.env.template credentials.env

# --- OpenAI ---
# Standard OpenAI API key (api.openai.com)
# OR Salesforce Research Gateway key (gateway.salesforceresearch.ai)
export OPENAI_API_KEY="your-openai-api-key"
# Uncomment for Salesforce Gateway:
# export OPENAI_BASE_URL="https://gateway.salesforceresearch.ai/openai/process/v1"

# --- Google Gemini ---
# Option A: Gemini API key (aistudio.google.com)
export GEMINI_API_KEY="your-gemini-api-key"
# Option B: Vertex AI (requires gcloud auth)
# export VERTEX_PROJECT="your-gcp-project-id"

# --- HuggingFace ---
# Required for downloading audio datasets
export HF_TOKEN="your-hf-token"
